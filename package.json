{
  "name": "@yog4a/nats",
  "description": "Personal encapsulation module for nats",
  "version": "2.0.4",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "node --import tsx --test tests/*.test.ts",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "dep:check": "npx npm-check-updates",
    "dep:install": "npx npm-check-updates -u && npm install",
    "tags:update": "git push --follow-tags"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@nats-io/jetstream": "^3.4.0",
    "@nats-io/kv": "^3.4.0",
    "@nats-io/nats-core": "^3.4.0",
    "@nats-io/transport-node": "^3.4.0",
    "snappy": "^7.3.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./clients": {
      "types": "./dist/clients.d.ts",
      "import": "./dist/clients.mjs",
      "require": "./dist/clients.cjs",
      "default": "./dist/clients.mjs"
    },
    "./libs": {
      "types": "./dist/libs.d.ts",
      "import": "./dist/libs.mjs",
      "require": "./dist/libs.cjs",
      "default": "./dist/libs.mjs"
    },
    "./modules": {
      "types": "./dist/modules.d.ts",
      "import": "./dist/modules.mjs",
      "require": "./dist/modules.cjs",
      "default": "./dist/modules.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.mjs",
      "require": "./dist/utils.cjs",
      "default": "./dist/utils.mjs"
    }
  }
}
